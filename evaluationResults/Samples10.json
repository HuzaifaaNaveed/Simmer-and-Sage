[
  {
    "name": "Beef Biryani",
    "ingredients": [
      "2 tablespoons vegetable oil",
      "1 1/2 lbs ground beef",
      "2 medium onions, finely chopped",
      "4 garlic cloves, finely minced",
      "6 green cardamom pods, crushed",
      "3 whole cloves",
      "5 whole black peppercorns",
      "15 fresh curry leaves",
      "1/4 teaspoon ground cinnamon",
      "1/2 teaspoon ground turmeric",
      "10 ounces frozen peas",
      "Salt",
      "1/3 cup plain yogurt",
      "8 ounces basmati rice",
      "3/4 teaspoon kosher salt",
      "20 ounces plain yogurt"
    ],
    "directions": [
      "Heat the oil in a large skillet on medium-high heat.",
      "Add the beef and cook until browned, about 5 minutes.",
      "Remove from the pan.",
      "Reduce heat to low and stir in the onions and garlic.",
      "Cook until softened, about 5–7 minutes.",
      "Stir in the spices and fry for another minute.",
      "Return the beef to the skillet; add peas, salt and yogurt.",
      "Bring to a boil.",
      "Cover and simmer for about 30 minutes until beef is tender.",
      "Strain the gravy and simmer for an additional 10 minutes.",
      "Cook the rice in salted water until tender.",
      "Drain the rice and soak in hot water for 5–10 minutes.",
      "Combine cooked rice with yogurt and beef."
    ]
  },
  {
    "name": "Tandoori Chicken",
    "ingredients": [
      "1/2 cup plain yogurt",
      "2 tablespoons fresh lemon juice",
      "1 teaspoon minced garlic",
      "3/4 teaspoon ground coriander",
      "4 teaspoons ground cumin",
      "6 green cardamom pods, lightly crushed",
      "5 dried chile peppers, broken",
      "Salt",
      "8 boneless skinless chicken breasts",
      "Fresh cilantro leaves",
      "Lemon wedges",
      "Steamed rice"
    ],
    "directions": [
      "Mix yogurt, lemon juice, garlic, coriander, cumin, cardamom and chilies. Add chicken and refrigerate 2 hours.",
      "Boil 3 cups water, add salt, then drain and soak rice.",
      "Cut chicken into 1-inch pieces and marinate 3 more hours.",
      "Remove chicken and shape into patties.",
      "Cook chicken in a pan until browned.",
      "Serve with lemon and rice."
    ]
  },
  {
    "name": "Pepperoni Pizza",
    "ingredients": [
      "1 cup pizza sauce",
      "2 teaspoons Italian seasoning",
      "1 teaspoon dried oregano",
      "8 slices pizza crust",
      "4 ounces pepperoni, diced",
      "3/4 cup mozzarella cheese"
    ],
    "directions": [
      "Preheat oven to 425°F.",
      "Mix pizza sauce with seasonings.",
      "Arrange crust on baking sheet.",
      "Top with pepperoni and mozzarella.",
      "Bake until cheese melts and crust is golden.",
      "Serve."
    ]
  },
  {
    "name": "Gulab Jamun",
    "ingredients": [
      "2 cups water",
      "1 cup sugar",
      "3 1/2 tablespoons corn syrup",
      "1/2 teaspoon cardamom powder",
      "6 cardamoms, crushed",
      "2 teaspoons saffron threads",
      "1/4 teaspoon rose essence",
      "8 cups milk",
      "4 cups water"
    ],
    "directions": [
      "Mix water, sugar, syrup, cardamom, rose essence, saffron and milk.",
      "Boil until thick.",
      "Add more milk if needed.",
      "Make balls from mixture.",
      "Let rest for 10 minutes.",
      "Heat ghee in a pan.",
      "Add gulab jamun mixture into ghee.",
      "Cook on low heat until golden brown.",
      "Serve hot or cold."
    ]
  },
  {
    "name": "Beef Burger",
    "ingredients": [
      "1 lb ground beef",
      "1 teaspoon minced garlic",
      "2 tablespoons chopped onion",
      "3 tablespoons chopped cilantro",
      "Salt and pepper to taste",
      "1/2 pita bread"
    ],
    "directions": [
      "Mix all ingredients.",
      "Divide into 6 portions.",
      "Roll each portion into a ball.",
      "Flatten into patties.",
      "Grill until cooked through.",
      "Serve with cilantro."
    ]
  },
  {
    "name": "Palak Paneer",
    "ingredients": [
      "1 1/2 cups chopped spinach",
      "1 teaspoon mustard seeds",
      "3 whole cloves",
      "2 black cardamom pods",
      "5 curry leaves",
      "4 green chilies",
      "6 cloves garlic",
      "8–10 green chilies",
      "Salt to taste",
      "1/4 cup grated paneer",
      "1 tablespoon butter",
      "Ghee (optional)",
      "5 tablespoons oil",
      "Fresh coriander"
    ],
    "directions": [
      "Heat oil and ghee.",
      "Add mustard seeds, cloves and cardamom.",
      "Add chilies and garlic; sauté.",
      "Add spinach, salt and curry leaves.",
      "Cook until spinach wilts and oil separates.",
      "Serve with paneer."
    ]
  },
  {
    "name": "Mango Lassi",
    "ingredients": [
      "1 cup mango pulp",
      "2 cups low-fat yogurt",
      "1/4 cup sugar",
      "3 tablespoons honey",
      "4 ice cubes"
    ],
    "directions": [
      "Blend all ingredients until smooth."
    ]
  },
  {
    "name": "Mutton Karahi",
    "ingredients": [
      "1 kg mutton",
      "2 onions sliced",
      "1 1/2 cups water",
      "4 tablespoons ginger-garlic paste",
      "1/2 teaspoon red chili powder",
      "Salt",
      "Oil"
    ],
    "directions": [
      "Cut mutton into small pieces.",
      "Boil onions, ginger garlic paste and water in pressure cooker.",
      "Add mutton and cook until tender.",
      "Heat oil and sauté onions.",
      "Add cooked mutton.",
      "Serve with roti."
    ]
  },
  {
    "name": "Shami Kabab",
    "ingredients": [
      "1 cup plain yogurt",
      "2 teaspoons salt",
      "4 tablespoons oil",
      "1 teaspoon cumin seeds",
      "5 whole cloves",
      "3 bay leaves",
      "8–10 green chilies",
      "6–7 peppercorns",
      "15–20 cardamom pods",
      "30 pieces beef or mutton",
      "1/2 onion sliced",
      "1/4 tomatoes sliced"
    ],
    "directions": [
      "Mix marinade and coat the meat; rest overnight.",
      "Bake meat at 200°C for 45 minutes.",
      "Bake onions and tomatoes for 10 minutes.",
      "Serve together."
    ]
  },
  {
    "name": "Tacos",
    "ingredients": [
      "1/2 cup shredded cheddar cheese",
      "1/4 cup chopped cilantro",
      "3 tablespoons chopped red onion",
      "2 minced garlic cloves",
      "Salt and pepper",
      "6 corn tortillas",
      "8 ounces grilled chicken"
    ],
    "directions": [
      "Mix cheese, cilantro, onions, garlic and seasoning.",
      "Cut tortillas and fill with mixture.",
      "Roll tortillas to enclose filling."
    ]
  }
]
